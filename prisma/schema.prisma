generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  role           Role     @default(VIEWER)
  status         String   @default("active")
  createdAt      DateTime @default(now())

  createdRecords Record[] @relation("CreatedRecords")
  updatedRecords Record[] @relation("UpdatedRecords")
}

model Record {
  id          Int      @id @default(autoincrement())
  amount      Float
  type        String
  category    String
  date        DateTime
  note        String?
  createdById Int
  createdBy   User     @relation("CreatedRecords", fields: [createdById], references: [id])
  updatedById Int?
  updatedBy   User?    @relation("UpdatedRecords", fields: [updatedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}